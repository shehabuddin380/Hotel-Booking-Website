{
    "builds": [{
        "src": "hotel_booking/wsgi.py",
        "use": "@vercel/python",
        "config": {
            "maxLambdaSize": "15mb",
            "runtime": "python3.11.3",
            "includeFiles": "staticfiles/**"
        }
    }],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "hotel_booking/wsgi.py"
        }
    ]
}